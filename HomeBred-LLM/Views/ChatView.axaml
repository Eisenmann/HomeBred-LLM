<UserControl x:Class="HomebredLLM.Views.ChatView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:HomebredLLM.Converters"
             xmlns:dconv="using:Avalonia.Data.Converters"
             xmlns:models="using:HomebredLLM.Models">

    <UserControl.Resources>
        <conv:RoleToBubbleColorConverter x:Key="BubbleColor" />
        <conv:RoleToAlignConverter x:Key="RoleAlign" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
        <conv:BytesToReadableConverter x:Key="BytesReadable" />
        <conv:PathToBitmapConverter x:Key="PathToBitmap" />
    </UserControl.Resources>

    <Grid ColumnDefinitions="220,*" DragDrop.AllowDrop="True">

        <!-- ── Session list ───────────────────────────────────────────── -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Model selector + new chat -->
                <StackPanel DockPanel.Dock="Top" Margin="10,10,10,6">
                    <TextBlock Text="Model" Classes="label" />
                    <ComboBox ItemsSource="{Binding RunningModels}"
                              SelectedItem="{Binding SelectedModel}"
                              DisplayMemberBinding="{Binding Name}" />
                    <Button Content="+ New Chat"
                            Classes="accent"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewSessionCommand}" />
                </StackPanel>

                <!-- Sessions -->
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession}"
                         Margin="6,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis"
                                           FontSize="12" />
                                <Button Grid.Column="1"
                                        Content="✕"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Padding="4,0"
                                        FontSize="11"
                                        Command="{Binding DataContext.DeleteSessionCommand,
                                            RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                        CommandParameter="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ── Chat window ─────────────────────────────────────────────── -->
        <Grid Grid.Column="1" RowDefinitions="*,Auto">

            <!-- Messages -->
            <ScrollViewer Grid.Row="0" x:Name="MessagesScroll"
                          VerticalScrollBarVisibility="Auto"
                          Padding="16,12">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Messages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Border MaxWidth="640"
                                            Background="{Binding Role, Converter={StaticResource BubbleColor}}"
                                            CornerRadius="12"
                                            Padding="12,8"
                                            HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                                        <StackPanel>
                                            <ItemsControl ItemsSource="{Binding Attachments}"
                                                          IsVisible="{Binding Attachments.Count, Converter={StaticResource BoolVis}}"
                                                          Margin="0,0,0,6">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,6,6" CornerRadius="8" ClipToBounds="True">
                                                            <Panel>
                                                                <Image Source="{Binding StoredPath, Converter={StaticResource PathToBitmap}}"
                                                                       IsVisible="{Binding Kind, Converter={x:Static dconv:ObjectConverters.Equal}, ConverterParameter={x:Static models:AttachmentKind.Image}}"
                                                                       Stretch="UniformToFill"
                                                                       MaxWidth="220" MaxHeight="160" />
                                                                <Border Background="#33000000"
                                                                        Padding="6,4"
                                                                        IsVisible="{Binding Kind, Converter={x:Static dconv:ObjectConverters.NotEqual}, ConverterParameter={x:Static models:AttachmentKind.Image}}">
                                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                                        <TextBlock Text="{Binding FileName}"
                                                                                   FontSize="11"
                                                                                   Foreground="White" />
                                                                        <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesReadable}}"
                                                                                   FontSize="10"
                                                                                   Foreground="#B0FFFFFF" />
                                                                    </StackPanel>
                                                                </Border>
                                                            </Panel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="{Binding Content}"
                                                       Foreground="White"
                                                       TextWrapping="Wrap"
                                                       FontSize="13" />
                                            <TextBlock FontSize="10"
                                                       Foreground="#80FFFFFF"
                                                       Margin="0,4,0,0"
                                                       IsVisible="{Binding TokensPerSecond,
                                                           Converter={StaticResource BoolVis}}"
                                                       Text="{Binding TokensPerSecond,
                                                           StringFormat='{}{0:F1} t/s'}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Streaming reply -->
                    <Border MaxWidth="640"
                            Background="{StaticResource BgCardBrush}"
                            CornerRadius="12"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,10"
                            IsVisible="{Binding IsGenerating}">
                        <TextBlock Text="{Binding StreamingReply}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="13" />
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Input bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgPanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,10">
                <StackPanel>

                    <!-- Pending attachment chips -->
                    <ItemsControl ItemsSource="{Binding PendingAttachments}"
                                  IsVisible="{Binding PendingAttachments.Count, Converter={StaticResource BoolVis}}"
                                  Margin="0,0,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgCardBrush}"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        Margin="0,0,6,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="11"
                                                   MaxWidth="160"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Content="✕"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Padding="2,0"
                                                FontSize="11"
                                                Foreground="{StaticResource TextMutedBrush}"
                                                Command="{Binding DataContext.RemovePendingAttachmentCommand,
                                                    RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <Button Grid.Column="0"
                                Content="📎"
                                ToolTip.Tip="Attach files"
                                Margin="0,0,6,0"
                                Click="Attach_Click" />
                        <Button Grid.Column="1"
                                Content="📁"
                                ToolTip.Tip="Attach folder"
                                Margin="0,0,8,0"
                                Click="AttachFolder_Click" />
                        <TextBox Grid.Column="2"
                                 Text="{Binding UserInput}"
                                 AcceptsReturn="False"
                                 Margin="0,0,8,0"
                                 Padding="10,8">
                            <TextBox.KeyBindings>
                                <KeyBinding Gesture="Return" Command="{Binding SendCommand}" />
                            </TextBox.KeyBindings>
                        </TextBox>
                        <StackPanel Grid.Column="3" Orientation="Horizontal">
                            <Button Content="Send ▶"
                                    Classes="accent"
                                    Command="{Binding SendCommand}"
                                    IsEnabled="{Binding IsGenerating,
                                        Converter={StaticResource BoolVis},
                                        ConverterParameter=inverse}"
                                    Margin="0,0,6,0" />
                            <Button Content="■ Stop"
                                    Classes="danger"
                                    Command="{Binding CancelGenerationCommand}"
                                    IsVisible="{Binding IsGenerating}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drag-and-drop highlight overlay -->
        <Border x:Name="DropHighlight"
                Grid.ColumnSpan="2"
                Background="#2260A5FA"
                BorderBrush="#6060A5FA"
                BorderThickness="2"
                Opacity="0"
                IsHitTestVisible="False" />
    </Grid>
</UserControl>
