<UserControl x:Class="HomebredLLM.Views.ModelConfigView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" MaxWidth="680">
            <TextBlock Classes="section-header">
                <Run Text="Configure — " />
                <Run Text="{Binding Model.Name, FallbackValue='Model'}" />
            </TextBlock>

            <Border Classes="card">
                <StackPanel>
                    <!-- Context size -->
                    <TextBlock Text="Context Size (tokens)" Classes="label" />
                    <Grid ColumnDefinitions="*,60" Margin="0,0,0,12">
                        <Slider Grid.Column="0"
                                Minimum="512" Maximum="131072"
                                Value="{Binding Config.ContextSize, Mode=TwoWay}"
                                TickFrequency="512"
                                VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Config.ContextSize}" />
                    </Grid>

                    <!-- Temperature -->
                    <TextBlock Text="Temperature" Classes="label" />
                    <Grid ColumnDefinitions="*,60" Margin="0,0,0,12">
                        <Slider Grid.Column="0"
                                Minimum="0" Maximum="2" TickFrequency="0.05"
                                Value="{Binding Config.Temperature, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Config.Temperature, StringFormat='{}{0:F2}'}" />
                    </Grid>

                    <!-- Top P -->
                    <TextBlock Text="Top P" Classes="label" />
                    <Grid ColumnDefinitions="*,60" Margin="0,0,0,12">
                        <Slider Grid.Column="0"
                                Minimum="0" Maximum="1" TickFrequency="0.05"
                                Value="{Binding Config.TopP, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Config.TopP, StringFormat='{}{0:F2}'}" />
                    </Grid>

                    <!-- Top K -->
                    <TextBlock Text="Top K" Classes="label" />
                    <TextBox Text="{Binding Config.TopK}" Margin="0,0,0,12" />

                    <!-- Repeat Penalty -->
                    <TextBlock Text="Repeat Penalty" Classes="label" />
                    <Grid ColumnDefinitions="*,60" Margin="0,0,0,12">
                        <Slider Grid.Column="0"
                                Minimum="1" Maximum="2" TickFrequency="0.05"
                                Value="{Binding Config.RepeatPenalty, Mode=TwoWay}"
                                VerticalAlignment="Center" Margin="0,0,10,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding Config.RepeatPenalty, StringFormat='{}{0:F2}'}" />
                    </Grid>

                    <!-- GPU Layers -->
                    <TextBlock Text="GPU Layer Count  (−1 = all on GPU)" Classes="label" />
                    <TextBox Text="{Binding Config.GpuLayerCount}" Margin="0,0,0,12" />

                    <!-- Threads -->
                    <TextBlock Text="CPU Threads" Classes="label" />
                    <TextBox Text="{Binding Config.ThreadCount}" Margin="0,0,0,12" />

                    <!-- Batch Size -->
                    <TextBlock Text="Batch Size" Classes="label" />
                    <TextBox Text="{Binding Config.BatchSize}" Margin="0,0,0,12" />

                    <!-- Max Tokens -->
                    <TextBlock Text="Max Output Tokens" Classes="label" />
                    <TextBox Text="{Binding Config.MaxTokens}" Margin="0,0,0,12" />

                    <!-- System Prompt -->
                    <TextBlock Text="System Prompt" Classes="label" />
                    <TextBox Text="{Binding Config.SystemPrompt}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="80"
                             Margin="0,0,0,16"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" />

                    <!-- Local API endpoint -->
                    <CheckBox Content="Enable local API endpoint (OpenAI-compatible)"
                              IsChecked="{Binding ApiServerEnabled, Mode=TwoWay}"
                              Margin="0,0,0,8" />
                    <StackPanel IsVisible="{Binding ApiServerEnabled}" Margin="0,0,0,16">
                        <TextBlock Text="Port" Classes="label" />
                        <TextBox Text="{Binding Config.ApiPort}" Margin="0,0,0,6" />
                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,2">
                            <Run Text="Bound to 127.0.0.1 only. Chat: " />
                            <Run Text="{Binding Config.ApiPort, StringFormat='http://127.0.0.1:{0}/v1/chat/completions'}"
                                 FontFamily="Consolas,monospace" />
                        </TextBlock>
                        <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap">
                            <Run Text="Embeddings: " />
                            <Run Text="{Binding Config.ApiPort, StringFormat='http://127.0.0.1:{0}/v1/embeddings'}"
                                 FontFamily="Consolas,monospace" />
                        </TextBlock>
                    </StackPanel>

                    <!-- LoRA adapters -->
                    <TextBlock Text="LoRA Adapters" Classes="label" Margin="0,4,0,2" />
                    <TextBlock Classes="muted" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Attach pre-trained GGUF LoRA adapters. Applied when the model starts — Stop and Start the model for changes to take effect." />

                    <ItemsControl ItemsSource="{Binding Adapters}" Margin="0,0,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="4"
                                        Padding="8" Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="*,72,Auto,Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBox Text="{Binding Name}" Watermark="Adapter name" />
                                            <TextBlock Text="{Binding FilePath}" Classes="muted"
                                                       FontSize="10" TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="Scale" Classes="muted" FontSize="10" />
                                            <TextBox Text="{Binding Scale, StringFormat='{}{0:F2}'}" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="2" Content="On"
                                                  IsChecked="{Binding Enabled}"
                                                  VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <Button Grid.Column="3" Content="🗑" Classes="ghost"
                                                VerticalAlignment="Center"
                                                Command="{Binding $parent[ItemsControl].DataContext.RemoveAdapterCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="＋ Add adapter…"
                            Classes="ghost"
                            Click="AddAdapter_Click"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,4" />
                    <TextBlock Text="{Binding AdapterError}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="💾 Save"
                                Classes="accent"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="↺ Reset Defaults"
                                Classes="ghost"
                                Command="{Binding ResetDefaultsCommand}" />
                        <TextBlock Text="{Binding SaveStatus}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
